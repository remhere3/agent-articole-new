# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# === Tavily ===
TAVILY_API_KEY=tvly-...

# === SearXNG ===
# Cate articole trimite SearXNG la Ollama pentru rezumare (cap per rulare)
SEARXNG_MAX_ARTICLES=25

# === Author (OpenAlex + CrossRef) ===
AUTHOR_MAX_WORKS=200      # lucrari/profil: OpenAlex paginat cu cursor (poate depasi 200) + rows CrossRef
AUTHOR_MAX_PROFILES=3     # cate profiluri de autor potrivite se proceseaza

# === Ollama ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=Agent Articole <your@gmail.com>

# === App ===
VERSION=1.2
APP_SECRET_KEY=change_this_secret_key
DATABASE_URL=sqlite:///./agent_articole.db
DEBUG=false
APP_PORT=8007

# === Notificari ntfy ===
NTFY_ENABLED=false
NTFY_TOPIC=agent-articole-xyz
# ntfy.sh (cloud):  NTFY_BASE_URL=https://ntfy.sh
# local (docker):   NTFY_BASE_URL=http://localhost:8080
NTFY_BASE_URL=https://ntfy.sh
